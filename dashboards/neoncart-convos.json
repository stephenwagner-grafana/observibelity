  "description": "NeonCart AI ops: agent traffic, latency, cost, and model mix. Rebuilt around gen_ai_* labels (ObserVIBElity canonical).",
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# NeonCart — AI Operations\n\nLive agent traffic, latency, cost, and model mix. Pick an agent and a time range. Spillover routes Ollama → Claude when Ollama's in-flight queue saturates; you'll see the Claude haiku line wake up under load."
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "At a glance",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "📞 Calls/min — all agents",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Operations per minute (5m rate × 60) across every NeonCart + SupportBot agent.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(gen_ai_client_time_to_first_token_seconds_count{gen_ai_system!=\"\", gen_ai_agent_name=~\"$agent\"}[5m])) * 60",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "💸 Cost rate — $/hr",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Spend rate (5m rate × 3600) for the selected agent.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(gen_ai_client_cost_USD_total{gen_ai_system!=\"\", gen_ai_agent_name=~\"$agent\"}[5m])) * 3600",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "⏱ p95 TTFT",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "95th-percentile time-to-first-token across the agent rotation. Green <2s · Orange 2-5s · Red >5s.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_time_to_first_token_seconds_bucket{gen_ai_system!=\"\", gen_ai_agent_name=~\"$agent\"}[5m])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "orange",
                "value": 2
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "🧮 Output tokens/min",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
