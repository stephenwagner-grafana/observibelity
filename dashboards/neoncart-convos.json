      "id": 6,
      "type": "timeseries",
      "title": "📞 Calls/min by agent",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Calls/min broken down by gen_ai_agent_name. Idle agents are hidden (>0 filter).",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (gen_ai_agent_name) (rate(gen_ai_client_time_to_first_token_seconds_count{gen_ai_system!=\"\", gen_ai_agent_name=~\"$agent\"}[5m])) * 60 > 0",
          "legendFormat": "{{gen_ai_agent_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
