      "id": 30,
      "description": "Count of POST /chat requests hitting NeonCart in the last hour, parsed from access logs (Loki). The basic 'is anyone shopping?' pulse.",
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "grafanacloud-logs"
          },
          "expr": "sum(count_over_time({container=\"neoncart\"} |~ \"POST /chat HTTP\" [1h]))",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "title": "NeonCart \u2014 how busy are we? (chats / hr)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
