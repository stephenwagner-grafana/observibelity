    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Live USD/hour rate for all NeonCart specialists combined.",
      "type": "stat",
      "title": "💸 NeonCart spend right now",
      "id": 101,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\",ai_o11y_specialist=~\"nc-.*\", gen_ai_system!=\"\"}[5m])) * 3600",
          "legendFormat": "$/hr",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      }
