          "expr": "histogram_quantile(0.95, sum by (le) (rate(gen_ai_client_operation_duration_seconds_bucket{service_namespace=\"observibelity\",ai_o11y_specialist=~\"sb-.*\", gen_ai_system!=\"\"}[5m])))",
          "legendFormat": "p95",
          "instant": true,
          "refId": "A"
