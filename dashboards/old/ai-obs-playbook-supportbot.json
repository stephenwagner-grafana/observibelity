        "h": 4,
        "w": 6,
        "x": 12,
        "y": 3
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum(rate({namespace=\"observibelity\",container=\"supportbot\"} |~ \"(?i)error\" [5m])) * 60",
          "legendFormat": "errors/min",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
