          },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\",ai_o11y_specialist=~\"sb-.*\", gen_ai_system!=\"\"}[5m])) * 60",
          "legendFormat": "calls/min",
          "instant": true,
          "refId": "A"
        }
