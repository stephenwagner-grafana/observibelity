  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "",
      "type": "timeseries",
      "title": "",
      "id": 100,
      "transparent": true,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_token_usage_total{service_namespace=\"observibelity\", gen_ai_system!=\"\"}[$__rate_interval])) * 60",
          "legendFormat": "tokens/min",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 100,
            "gradientMode": "scheme",
            "lineWidth": 0,
            "axisPlacement": "hidden",
            "showPoints": "never",
            "spanNulls": false,
            "hideFrom": {
              "legend": true,
              "tooltip": false,
              "viz": false
            },
            "stacking": {
              "group": "A",
              "mode": "none"
            }
          },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 30
              },
              {
                "color": "#F472B6",
                "value": 65
              },
              {
                "color": "#FB923C",
                "value": 88
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Live USD/hour rate for all Support Bot specialists combined.",
      "type": "stat",
      "title": "💸 Support Bot spend right now",
      "id": 101,
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 3
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\",ai_o11y_specialist=~\"sb-.*\", gen_ai_system!=\"\"}[5m])) * 3600",
          "legendFormat": "$/hr",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "values": false,
          "calcs": [
            "lastNotNull"
          ],
          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
