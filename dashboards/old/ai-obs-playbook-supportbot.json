          "fields": ""
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "5-minute p95 of GenAI client operation duration across all Support Bot specialists.",
      "type": "stat",
      "title": "⏱ Support Bot p95 latency",
      "id": 104,
