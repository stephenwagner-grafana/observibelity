            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 50
                    },
                    {
                      "color": "red",
                      "value": 200
                    }
                  ]
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Offender score"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "green",
                      "value": null
                    },
                    {
                      "color": "yellow",
                      "value": 5
                    },
                    {
                      "color": "red",
                      "value": 25
                    }
                  ]
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 12,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "id": 9,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Offender score"
          }
        ]
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\"}[24h]))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Cost"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (user_id) (increase(gen_ai_client_token_usage_total{user_id!=\"\"}[24h]))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Tokens"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\", ai_o11y_usecase=\"high-waste\"}[24h])) > 0 or on() vector(0)",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Waste"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "( sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\"}[24h])) / scalar(max(sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\"}[24h])))) * 100 ) + ( sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\", ai_o11y_usecase=\"high-waste\"}[24h])) / scalar(max(sum by (user_id) (increase(gen_ai_client_cost_USD_total{user_id!=\"\", ai_o11y_usecase=\"high-waste\"}[24h]))) or vector(1)) * 100 )",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Score"
        }
      ],
      "title": "Worst-offenders leaderboard (cost + waste, 24h)",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "user_id",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "indexByName": {
              "user_id": 0,
              "Value #Cost": 1,
              "Value #Tokens": 2,
              "Value #Waste": 3,
              "Value #Score": 4
            },
            "renameByName": {
              "Value #Cost": "Cost (24h, USD)",
              "Value #Tokens": "Tokens (24h)",
              "Value #Waste": "Waste calls (24h)",
              "Value #Score": "Offender score"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "Offender score"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 45
      },
      "id": 100,
      "panels": [],
      "title": "AI quality score (0-100, scored LLM judge)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Fleet-wide average AI quality score (0-100). LLM-judge `quality.business_value_score` scores every sampled prompt 0=trivial, 50=ambiguous, 100=clearly productive work. Sigil emits sigil_eval_scores_total (running sum) and sigil_eval_executions_total (count); avg = sum / count.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "green",
                "value": 70
              }
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 100
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 46
      },
      "id": 101,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showPercentChange": false,
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "expr": "( sum(rate(sigil_eval_scores_total{evaluator=\"quality.business_value_score\"}[1h])) / sum(rate(sigil_eval_executions_total{evaluator=\"quality.business_value_score\"}[1h])) ) or vector(0)",
          "instant": true,
          "legendFormat": "Fleet avg",
          "refId": "A"
        }
      ],
      "title": "Fleet AI quality score (1h avg)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Per-user average AI quality score (0-100), sorted ascending \u2014 lowest scorers (worst offenders) on top. A user persistently below 30 is using the AI for trivia / personal / off-topic content. Empty if sampling hasn't kicked in yet OR if the Sigil evaluator isn't wired up (Sigil v0.17 needs UI creation).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 30
