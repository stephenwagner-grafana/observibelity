      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "Calls",
          "expr": "sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h]))"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "Tokens",
          "expr": "sum by (user_id) (increase(gen_ai_client_token_usage_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h]))"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "Cost",
          "expr": "sum by (user_id) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h]))"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "Waste",
          "expr": "( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_usecase=\"high-waste\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) ) * 100 or label_replace(sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) * 0, \"placeholder\",\"\",\"\",\"\")"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "Quality",
          "expr": "label_replace( sum(rate(sigil_eval_scores_total{evaluator=\"quality.business_value_score\"}[1h])) / sum(rate(sigil_eval_executions_total{evaluator=\"quality.business_value_score\"}[1h])) * 100, \"user_id\", \"$1\", \"user_id\", \"(.*)\")"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "format": "table",
          "instant": true,
          "range": false,
          "refId": "ProblemScore",
          "expr": "( (sum by (user_id) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / scalar(max(sum by (user_id) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])))) ) * 50 ) + ( ( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_usecase=\"high-waste\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) ) * 0.5 )"
        }
      ],
      "title": "Top problem users \u2014 cost + tokens + waste % + quality + combined score",
