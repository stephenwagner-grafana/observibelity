{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "liveNow": false,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "observibelity"
      ],
      "title": "ObserVIBElity dashboards",
      "type": "dashboards"
    }
  ],
  "description": "Live SRE failure + AI behavior. Operational health left, AI traffic on the right. Spillover events on the bottom.",
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 4,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "mode": "markdown",
        "content": "# NeonCart Demo \u2014 SRE Failure + AI Behavior\n\n**Left:** k3s + pod/service health.  **Right:** AI traffic, errors, and spillover.  Watch the Claude haiku line wake up when Ollama queue saturates and the gateway routes overflow to Anthropic."
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "Cluster + pods",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "stat",
      "title": "\ud83e\udde0 k3s nodes Ready",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Count of k3s nodes reporting Ready=true.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(kube_node_status_condition{cluster=\"k3s\", condition=\"Ready\", status=\"true\"} == 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 3
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "\ud83d\udce6 k6-traffic pods Running",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Count of k6-traffic loadgen pods in Running phase.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(kube_pod_status_phase{namespace=\"observibelity\", pod=~\"k6-traffic-.*\", phase=\"Running\"} == 1)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "green",
                "value": 2
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "\ud83d\udd01 Pod restarts (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Restart count change over the last 5 minutes across NeonCart, llm-gateway, and loadgen pods. Any non-zero value is suspicious.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(changes(kube_pod_container_status_restarts_total{namespace=\"observibelity\", pod=~\"k6-traffic-.*|llm-gateway-.*|neoncart-.*|nc-.*\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "\ud83d\udd25 NeonCart errors/min (Loki)",
      "datasource": {
        "type": "loki",
        "uid": "${loki}"
      },
      "description": "Error-level lines from the neoncart container, summed over 5m and scaled to per-minute.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 5
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki}"
          },
          "expr": "sum(rate({namespace=\"observibelity\", container=\"neoncart\"} |~ \"(?i)error\" [5m])) * 60",
          "queryType": "instant",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area"
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "AI traffic & spillover",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "panels": []
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "\ud83e\udeaa Model mix \u2014 calls/min",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Per-model traffic on llm-gateway. Claude haiku spikes are spillover when Ollama in-flight saturates and daily Claude budget allows.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 11
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_time_to_first_token_seconds_count{service_namespace=\"observibelity\", gen_ai_system!=\"\"}[5m])) * 60 > 0",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "claude-haiku-4-5-20251001"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F472B6"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 3
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "right"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "\u23f1 p95 TTFT \u2014 Ollama vs Anthropic",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "P95 time-to-first-token split by gen_ai_system. Anthropic should beat Ollama when it kicks in.",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 11
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "histogram_quantile(0.95, sum by (gen_ai_system, le) (rate(gen_ai_client_time_to_first_token_seconds_bucket{service_namespace=\"observibelity\", gen_ai_system!=\"\"}[5m])))",
          "legendFormat": "{{gen_ai_system}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 2,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 8,
            "lineWidth": 2,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "anthropic"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F472B6"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ollama"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#67E8F9"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 102,
      "type": "row",
      "title": "Business impact",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "panels": []
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "\ud83d\uded2 Add-to-cart events/min by model",
      "datasource": {
        "type": "loki",
        "uid": "${loki}"
      },
      "description": "ATC events parsed from loadgen log lines, broken down by the model that produced the recommendation.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 21
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki}"
          },
          "expr": "sum by (model) (rate({namespace=\"observibelity\", container=\"tool\"} |~ \"atc_event source=loadgen\" | regexp `model=(?P<model>[a-zA-Z0-9._:-]+)` [5m])) * 60",
          "legendFormat": "{{model}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 1,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "\ud83d\udcb8 Cost rate by system ($/hr)",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Spend rate split by gen_ai_system. Ollama is free; anthropic is real money.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 21
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (gen_ai_system) (rate(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", gen_ai_system!=\"\"}[5m])) * 3600",
          "legendFormat": "{{gen_ai_system}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "decimals": 3,
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 25,
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "anthropic"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F472B6"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ollama"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#67E8F9"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
