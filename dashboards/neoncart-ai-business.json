{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Headline",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "AI recommendation impressions (gift-finder + product-recommender) over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "purple",
            "mode": "fixed"
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Recommendations served",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "% of recommendation impressions that resulted in an add-to-cart within 5 min. Shows whether customers find AI suggestions useful.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "green",
                "value": 0.25
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_recommendation_addtocart_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum(increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "refId": "A"
        }
      ],
      "title": "Rec → Add-to-Cart",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "% of recommendation impressions that turned into a paid line item. The bottom of the funnel.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "green",
                "value": 0.15
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_recommendation_purchase_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum(increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "refId": "A"
        }
      ],
      "title": "Rec → Purchase",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Dollars from line items that were a recently-recommended product.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "fixedColor": "green",
            "mode": "fixed"
          },
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_recommendation_purchase_revenue_dollars{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "AI-attributed revenue",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 200,
      "title": "Quality vs conversion — does eval matter?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "If \"good\" recommendations convert noticeably higher than \"bad\" ones, the eval is doing its job.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "green",
                "value": 0.25
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 7
      },
      "id": 5,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "sum by (eval_result) (increase(ai_recommendation_addtocart_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum by (eval_result) (increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "legendFormat": "{{eval_result}}",
          "refId": "A"
        }
      ],
      "title": "Add-to-cart rate by eval_result",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Conversion all the way to checkout, split by eval result.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "green",
                "value": 0.15
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 7
      },
      "id": 6,
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "targets": [
        {
          "expr": "sum by (eval_result) (increase(ai_recommendation_purchase_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum by (eval_result) (increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "legendFormat": "{{eval_result}}",
          "refId": "A"
        }
      ],
      "title": "Purchase rate by eval_result",
      "type": "bargauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Share of recommendations the eval scored as good / bad / none. \"none\" means we never ran an eval.",
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 7
      },
      "id": 7,
      "options": {
        "displayLabels": [
          "name",
          "percent"
        ],
        "legend": {
          "displayMode": "list",
          "placement": "right",
          "values": [
            "value",
            "percent"
          ]
        },
        "pieType": "donut"
      },
      "targets": [
        {
          "expr": "sum by (eval_result) (increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "legendFormat": "{{eval_result}}",
          "refId": "A"
        }
      ],
      "title": "Recommendation quality mix",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 250,
      "title": "AI Output Quality (structured eval)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Share of recommendation evaluations scored as `good`. From ai_eval_total{result=...}, computed over the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.6
              },
              {
                "color": "green",
                "value": 0.85
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 0,
        "y": 16
      },
      "id": 251,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_eval_total{result=\"good\", specialist=~\"$specialist\"}[$__range])) / clamp_min(sum(increase(ai_eval_total{specialist=~\"$specialist\"}[$__range])), 1)",
          "refId": "A"
        }
      ],
      "title": "AI Quality (Good %)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Mean of ai_eval_score over the dashboard time range. 1.0 = ideal recommendation, 0.0 = unusable.",
      "fieldConfig": {
        "defaults": {
          "decimals": 2,
          "max": 1,
          "min": 0,
          "noValue": "—",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 0.8
              }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 6,
        "y": 16
      },
      "id": 252,
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "expr": "sum(increase(ai_eval_score_sum{specialist=~\"$specialist\"}[$__range])) / clamp_min(sum(increase(ai_eval_score_count{specialist=~\"$specialist\"}[$__range])), 1)",
          "refId": "A"
        }
      ],
      "title": "Average Eval Score",
      "type": "gauge"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Breakdown of failed evals by primary reason. Drives improvements: a spike in `missing_products` means the prompt isn't anchoring the model to catalog IDs.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "noValue": "—",
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 12,
        "y": 16
      },
      "id": 253,
      "options": {
        "legend": {
          "displayMode": "hidden",
          "placement": "bottom"
        },
        "orientation": "horizontal",
        "showValue": "always",
        "stacking": "none",
        "xTickLabelRotation": 0
      },
      "targets": [
        {
          "expr": "sum by (reason) (increase(ai_eval_total{result=\"bad\", specialist=~\"$specialist\"}[$__range]))",
          "format": "table",
          "instant": true,
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "title": "Why Recommendations Fail",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Good vs bad evals per minute. The trend line tells a quality-over-time story; correlate dips with model rollouts or prompt changes.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          },
          "unit": "cpm"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "good"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "bad"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "red",
                  "mode": "fixed"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 7,
        "w": 6,
        "x": 18,
        "y": 16
      },
      "id": 254,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "expr": "60 * sum by (result) (rate(ai_eval_total{specialist=~\"$specialist\"}[5m]))",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ],
      "title": "Evaluation Trend Over Time",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 23
      },
      "id": 300,
      "title": "Funnel — impression → cart → buy",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Stacked view of impressions, add-to-carts, and purchases. The drop-off shape is the funnel.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "lineWidth": 0
          },
          "unit": "cpm"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 16,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "60 * sum(rate(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[5m]))",
          "legendFormat": "impressions",
          "refId": "A"
        },
        {
          "expr": "60 * sum(rate(ai_recommendation_addtocart_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[5m]))",
          "legendFormat": "added to cart",
          "refId": "B"
        },
        {
          "expr": "60 * sum(rate(ai_recommendation_purchase_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[5m]))",
          "legendFormat": "purchased",
          "refId": "C"
        }
      ],
      "title": "Funnel rate (events / min)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Total events in the dashboard time range.",
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 24
      },
      "id": 9,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "orientation": "vertical",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "expr": "sum(increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "legendFormat": "Impressions",
          "refId": "A"
        },
        {
          "expr": "sum(increase(ai_recommendation_addtocart_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "legendFormat": "Added to cart",
          "refId": "B"
        },
        {
          "expr": "sum(increase(ai_recommendation_purchase_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range]))",
          "legendFormat": "Purchased",
          "refId": "C"
        }
      ],
      "title": "Funnel summary",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 400,
      "title": "Budget × Model — should we route bigger asks to a stronger model?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "If a model's purchase rate falls off in the higher budget rows, that's the signal to route those requests to a stronger model.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.05
              },
              {
                "color": "green",
                "value": 0.15
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 33
      },
      "id": 10,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "sum by (budget_bucket, model) (increase(ai_recommendation_purchase_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum by (budget_bucket, model) (increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Purchase rate by budget × model",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Purchase rate",
              "budget_bucket": "Budget",
              "model": "Model"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "description": "Earlier-funnel signal: which model is producing carts at each budget tier?",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": 0.1
              },
              {
                "color": "green",
                "value": 0.25
              }
            ]
          },
          "unit": "percentunit"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 33
      },
      "id": 11,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "expr": "sum by (budget_bucket, model) (increase(ai_recommendation_addtocart_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])) / clamp_min(sum by (budget_bucket, model) (increase(ai_recommendation_total{specialist=~\"$specialist\", budget_bucket=~\"$budget\"}[$__range])), 1)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Add-to-cart rate by budget × model",
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "renameByName": {
              "Value": "Add-to-cart rate",
              "budget_bucket": "Budget",
              "model": "Model"
            }
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
