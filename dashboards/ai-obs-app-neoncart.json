    {
      "datasource": {
        "type": "tempo",
        "uid": "${datasource_tempo}"
      },
      "description": "Recent NeonCart traces filtered by the selected use case. Click a row to open the span tree.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 6
      },
      "id": 8,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "${datasource_tempo}"
          },
          "filters": [],
          "limit": 20,
          "query": "{ resource.service.name=\"neoncart\" && .ai_o11y.usecase=\"$use_case\" }",
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Recent NeonCart traces (use_case=$use_case)",
      "type": "traces"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${datasource_tempo}"
      },
      "description": "Pivot here to inspect the latest mice-rca error trace end-to-end. The mice-rca use case raises an UndefinedColumn error in the pg.query tool span — this panel surfaces those traces so you can walk the span tree from the user request down to the failing SQL.",
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 6
      },
      "id": 9,
      "targets": [
        {
          "datasource": {
            "type": "tempo",
            "uid": "${datasource_tempo}"
          },
          "filters": [],
          "limit": 20,
          "query": "{ .ai_o11y.usecase=\"mice-rca\" && status=error }",
          "queryType": "traceqlSearch",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Show me mice — trace pivot",
      "type": "traces"
    },
