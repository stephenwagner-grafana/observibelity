          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_cost_USD_total[5m]))",
          "format": "time_series",
          "instant": false,
          "legendFormat": "{{gen_ai_request_model}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "💰 Spend rate per model over time (5m sliding)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "p95 of gen_ai client request duration per model — 95 out of 100 calls finish faster than this. Spikes here mean tail-latency pain that users will feel.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
