{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${datasource_loki}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "blue",
        "name": "Model rollouts",
        "target": {
          "expr": "{service=\"llm-gateway\"} | json | event=\"model.rollout\"",
          "queryType": "range",
          "refId": "Annotations"
        },
        "textFormat": "model rollout: {{ model }}"
      }
    ]
  },
  "description": "Rank models by ATC + purchase events, not by offline eval scores. Cheapest performant model wins.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "observibelity"
      ],
      "title": "AI Observability dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "🏆 Which model is winning right now?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Top 10 models ranked by Add-to-Cart events in the last hour, taken from the NeonCart chatbot's input token traffic. Eval scores are theory; ATC is a real business outcome.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "axisBorderShow": false,
            "axisCenteredZero": false,
            "axisColorMode": "text",
            "axisLabel": "",
            "axisPlacement": "auto",
            "fillOpacity": 80,
            "gradientMode": "scheme",
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "lineWidth": 1
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "legend": {
          "calcs": [],
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": false
        },
        "orientation": "horizontal",
        "showValue": "auto",
        "stacking": "none",
        "tooltip": {
          "mode": "single",
          "sort": "none"
        },
        "xTickLabelRotation": 0,
        "xTickLabelSpacing": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "topk(10, sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[1h])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{gen_ai_request_model}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "🤖 Which models drove the most Add-to-Carts? (1h)",
      "type": "barchart"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Same data as the bar chart on the left, laid out as a horizontal leaderboard. Use whichever shape your eye prefers.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 24,
        "minVizWidth": 8,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "topk(10, sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[1h])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{gen_ai_request_model}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "🔥 ATC leaderboard — same data, leaderboard view (1h)",
      "type": "bargauge"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "id": 4,
      "panels": [],
      "title": "📈 How is each model trending — and which is cheapest per ATC?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Add-to-Cart rate per model over time (5m sliding window). Use this to see model rotations or rollouts taking effect — one model rising as another falls.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "pointSize": 4,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 11
      },
      "id": 5,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[5m]))",
          "format": "time_series",
          "instant": false,
          "legendFormat": "{{gen_ai_request_model}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "ATC rate per model over time (5m sliding)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "USD spent per ATC event for each model, last hour. The lowest number is the model giving you the most conversions for your dollar. Green is good.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.01
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 11
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_cost_USD_total{ai_o11y_specialist=\"nc-chatbot\"}[1h])) / clamp_min(sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[1h])), 0.0001)",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{gen_ai_request_model}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "💸 Cheapest model per ATC (lower is better, 1h)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "id": 7,
      "panels": [],
      "title": "📋 The full scorecard — every metric, every model",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "One row per model with every signal you need to pick a winner: ATC volume, output/input token ratio (proxy for verbosity), p50 latency, and dollars per ATC. Sort by any column. All numbers are 1h windows.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "gen_ai_request_model"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Model"
              },
              {
                "id": "custom.width",
                "value": 260
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Total ATC (1h)"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Conversion %"
              },
              {
                "id": "unit",
                "value": "percentunit"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Avg latency"
              },
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #D"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "USD / conversion"
              },
              {
                "id": "unit",
                "value": "currencyUSD"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 21
      },
      "id": 8,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Total ATC (1h)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[1h]))",
          "format": "table",
          "instant": true,
          "legendFormat": "ATC events",
          "range": false,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[1h])) / clamp_min(sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[1h])), 0.001)",
          "format": "table",
          "instant": true,
          "legendFormat": "output/input token ratio",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "histogram_quantile(0.5, sum by (gen_ai_request_model, le) (rate(gen_ai_client_operation_duration_seconds_bucket[1h])))",
          "format": "table",
          "instant": true,
          "legendFormat": "p50 latency",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_cost_USD_total{ai_o11y_specialist=\"nc-chatbot\"}[1h])) / clamp_min(sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_total{ai_o11y_specialist=\"nc-chatbot\",gen_ai_token_type=\"input\"}[1h])), 0.0001)",
          "format": "table",
          "instant": true,
          "legendFormat": "$ / req",
          "range": false,
          "refId": "D"
        }
      ],
      "title": "🏁 Full leaderboard — ATC, conversion, latency, $ per ATC (1h)",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "gen_ai_request_model",
            "mode": "outer"
          }
        }
      ],
      "type": "table"
    },
    {
