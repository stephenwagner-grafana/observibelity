          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum(count_over_time({container=\"llm-gateway\"} |~ \"(?i)(ssn|social security)\" [5m]))",
          "legendFormat": "ssn",
          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
