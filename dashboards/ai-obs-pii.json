      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum(rate(supportbot_pii_redacted_total[5m])) / clamp_min(sum(rate(supportbot_pii_match_total[5m])), 0.001)",
          "refId": "A"
