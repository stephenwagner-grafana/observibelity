            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum(count_over_time({container=\"llm-gateway\"} |~ \"(?i)(password|api[ -]?key|bearer )\" [5m]))",
          "legendFormat": "secret",
          "queryType": "range",
          "refId": "C"
        }
      ],
      "title": "📈 PII detected by kind over time (5m)",
      "type": "timeseries"
