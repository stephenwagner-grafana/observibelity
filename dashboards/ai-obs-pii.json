      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum by (kind) (rate(supportbot_pii_match_total[5m]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
