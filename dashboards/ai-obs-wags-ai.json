          "unit": "Bps"
        }
      },
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource_prom}"}, "expr": "sum by (device) (rate(node_disk_read_bytes_total{host=\"wags-ai\", device=~\"nvme.*|sd.*\"}[$__rate_interval]))", "legendFormat": "{{device}}"}],
      "transparent": true
    },
    {
      "id": 57,
      "title": "ECC errors (uncorrected, volatile)",
      "description": "Should be flat at zero forever. Any rise = a hardware issue.",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "gridPos": {"h": 7, "w": 12, "x": 12, "y": 77},
      "options": {
        "colorMode": "value", "graphMode": "area",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "value", "justifyMode": "center"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [{"type": "value", "options": {"0": {"text": "0 — good", "color": "#86EFAC", "index": 0}, "-1": {"text": "N/A on consumer GPU", "color": "#4B5563", "index": 1}}}],
          "color": {"mode": "thresholds"},
          "thresholds": {"mode": "absolute", "steps": [
            {"value": null, "color": "#86EFAC"},
            {"value": 1, "color": "#F472B6"}
