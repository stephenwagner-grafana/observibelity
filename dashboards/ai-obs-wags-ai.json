          {"matcher": {"id": "byName", "options": "Vision"}, "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "—", "color": "transparent"}, "1": {"text": "✓", "color": "#A78BFA"}}}]}]},
          {"matcher": {"id": "byName", "options": "Sys prompt"}, "properties": [{"id": "mappings", "value": [{"type": "value", "options": {"0": {"text": "—", "color": "transparent"}, "1": {"text": "yes", "color": "#FB923C"}}}]}]}
        ]
