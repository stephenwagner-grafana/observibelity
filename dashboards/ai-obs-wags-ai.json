          "unit": "short"
        }
      },
      "targets": [{"refId": "A", "datasource": {"type": "prometheus", "uid": "${datasource_prom}"}, "expr": "max(nvidia_gpu_ecc_errors_uncorrected_volatile_total{host=\"wags-ai\"}) or vector(-1)"}],
      "transparent": true
    },
    {
      "id": 58,
      "title": "Model architecture & capabilities (Sigil can't see this)",
      "description": "From /api/show. Tool/vision flags = advertised capability. Context length / vocab / param count = architecture facts that explain quality and latency.",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 84},
      "options": {"showHeader": true, "cellHeight": "sm", "sortBy": [{"displayName": "Params", "desc": true}]},
