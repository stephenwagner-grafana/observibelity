      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "max(nvidia_gpu_temperature_gpu_celsius{host=\"wags-ai\"})"
        }
      ],
      "transparent": true
    },
    {
      "id": 10,
      "title": "💾 VRAM occupancy & model lifecycle",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 9
      },
      "collapsed": false,
      "panels": [],
      "transparent": true
    },
    {
      "id": 11,
      "title": "VRAM by model (stacked) — watch this for eviction cycles",
      "description": "Stacked area showing how much VRAM each loaded model holds. When the stack collapses and a new layer appears, a model was evicted to load another — the AI-justifies-AI thrash signature.",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 10
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "showLegend": true,
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 60,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "stacking": {
              "mode": "normal",
              "group": "A"
            },
            "spanNulls": true,
            "axisPlacement": "auto",
            "axisLabel": ""
          },
          "color": {
            "mode": "palette-classic"
          },
          "unit": "decbytes"
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "gemma2:2b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#86EFAC"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "llama3.2:1b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F472B6"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "phi3:mini"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FB923C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "qwen2.5:7b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FCA5A5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tinyllama:1.1b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FCD34D"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ollama"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#67E8F9"
                }
              }
            ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "ollama_loaded_model_size_vram_bytes{host=\"wags-ai\"}",
          "legendFormat": "{{model}}"
        }
      ],
      "transparent": true
    },
    {
      "id": 12,
      "title": "Currently loaded models",
      "description": "Sorted by VRAM resident. Expires_in is seconds until Ollama would idle-evict it (negative = stale).",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 20
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "sortBy": [
          {
            "displayName": "VRAM",
            "desc": true
          }
        ]
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "VRAM"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Size on disk"
            },
            "properties": [
              {
                "id": "unit",
                "value": "decbytes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Expires in"
            },
            "properties": [
              {
                "id": "unit",
                "value": "s"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "gemma2:2b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#86EFAC"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "llama3.2:1b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F472B6"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "phi3:mini"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FB923C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "qwen2.5:7b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FCA5A5"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "tinyllama:1.1b"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FCD34D"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ollama"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#67E8F9"
                }
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "joinByLabels",
          "options": {
            "value": "model",
            "join": [
              "family",
              "parameter_size",
              "quantization"
            ]
          }
        },
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "model": "Model",
              "family": "Family",
              "parameter_size": "Size",
              "quantization": "Quant",
              "Value #VRAM": "VRAM",
              "Value #SIZE": "Size on disk",
              "Value #EXP": "Expires in"
            },
            "excludeByName": {
              "host": true,
              "cluster": true,
              "instance": true,
              "job": true,
              "Time": true,
              "digest": true
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "VRAM",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "ollama_loaded_model_size_vram_bytes{host=\"wags-ai\"} * on(model) group_left(family, parameter_size, quantization) ollama_loaded_model_info{host=\"wags-ai\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "SIZE",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "ollama_loaded_model_size_bytes{host=\"wags-ai\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "EXP",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "ollama_loaded_model_expires_seconds{host=\"wags-ai\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transparent": true
    },
