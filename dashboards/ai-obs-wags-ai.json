            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "avg(nvidia_gpu_power_draw_watts{host=\"wags-ai\", name=\"NVIDIA_GeForce_RTX_5090\"})"
        }
      ],
      "transparent": true
    },
    {
      "id": 5,
      "title": "GPU temperature",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "justifyMode": "center",
        "wideLayout": false,
        "percentChangeColorMode": "inverted"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 60
              },
              {
                "color": "#F472B6",
                "value": 80
              }
            ]
          },
          "unit": "celsius",
          "decimals": 0
