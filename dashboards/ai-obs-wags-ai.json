{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${datasource_logs}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "#F472B6",
        "name": "Ollama model loads",
        "target": {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_logs}"
          },
          "expr": "{host=\"wags-ai\", unit=\"ollama.service\"} |~ \"(?i)(load model|llm load progress|llama_model_load|new model load)\"",
          "refId": "Annotations"
        },
        "titleFormat": "Ollama load",
        "textFormat": "{{__line__}}"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${datasource_logs}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "#A78BFA",
        "name": "Ollama evictions",
        "target": {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_logs}"
          },
          "expr": "{host=\"wags-ai\", unit=\"ollama.service\"} |~ \"(?i)(unload|stopped server|free memory|removing model)\"",
          "refId": "Annotations"
        },
        "titleFormat": "Ollama eviction",
        "textFormat": "{{__line__}}"
      }
    ]
  },
  "description": "Live view of the wags-ai AI workstation (192.168.2.240, RTX 5090, bare-metal Ollama). Built so natural VRAM thrash and model lifecycle events are obvious without staging.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "observibelity"
      ],
      "title": "ObserVIBElity dashboards",
      "type": "dashboards"
    }
  ],
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "",
      "type": "timeseries",
      "title": "",
      "id": 100,
      "transparent": true,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_token_usage_total[$__rate_interval])) * 60",
          "legendFormat": "tokens/min",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "barWidthFactor": 0.92,
            "fillOpacity": 100,
            "gradientMode": "scheme",
            "lineWidth": 0,
            "axisPlacement": "hidden",
            "axisLabel": "",
            "axisColorMode": "text",
            "showPoints": "never",
            "spanNulls": false,
            "hideFrom": {
              "legend": true,
              "tooltip": false,
              "viz": false
            },
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 30
              },
              {
                "color": "#F472B6",
                "value": 65
              },
              {
                "color": "#FB923C",
                "value": 88
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "id": 1,
      "title": "🤖 wags-ai right now — RTX 5090 + Ollama",
      "type": "row",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "collapsed": false,
      "panels": [],
      "transparent": true
    },
    {
      "id": 2,
      "title": "VRAM in use",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "justifyMode": "center",
        "wideLayout": false,
        "percentChangeColorMode": "inverted"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 0.6
              },
              {
                "color": "#F472B6",
                "value": 0.9
              }
            ]
          },
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(nvidia_gpu_memory_used_bytes{host=\"wags-ai\"}) / sum(nvidia_gpu_memory_total_bytes{host=\"wags-ai\"})"
        }
      ],
      "transparent": true
    },
    {
      "id": 3,
      "title": "Models loaded in VRAM",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "justifyMode": "center",
        "wideLayout": false,
        "percentChangeColorMode": "inverted"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#FB923C",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 1
              },
              {
                "color": "#8AB8FF",
                "value": 4
              }
            ]
          },
          "unit": "short"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "max(ollama_loaded_models{host=\"wags-ai\"})"
        }
      ],
      "transparent": true
    },
    {
      "id": 4,
      "title": "GPU power draw",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 4
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "justifyMode": "center",
        "wideLayout": false,
        "percentChangeColorMode": "inverted"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 200
              },
              {
                "color": "#F472B6",
                "value": 400
              }
            ]
          },
          "unit": "watt",
          "decimals": 0
