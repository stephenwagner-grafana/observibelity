        {"refId": "VISION", "datasource": {"type": "prometheus", "uid": "${datasource_prom}"}, "expr": "max by (model) (ollama_model_capability{host=\"wags-ai\", capability=\"vision\"}) or max by (model) (ollama_model_context_length{host=\"wags-ai\"}) * 0", "format": "table", "instant": true},
        {"refId": "SYS",    "datasource": {"type": "prometheus", "uid": "${datasource_prom}"}, "expr": "ollama_model_has_system_prompt{host=\"wags-ai\"}", "format": "table", "instant": true}
