          "queryType": "range",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum by (user_id) (count_over_time({container=\"llm-gateway\"} |~ \"(?i)(hiring|candidate|race|gender|age|disability|religion)\" | json | ai_o11y_specialist=~\"sb-.*\" | user_id=~\".*@.*\" [24h]))",
