          },
          "expr": "100 - 10 * sum by (user_id) (count_over_time({container=\"llm-gateway\"} | json | ai_o11y_specialist=\"sb-security-handler\" | user_id=~\".*@.*\" [24h]))",
          "legendFormat": "compliance score",
          "queryType": "range",
          "refId": "C"
