          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum by (user_id) (count_over_time({container=\"llm-gateway\"} | json | ai_o11y_specialist=\"sb-security-handler\" | user_id=~\".*@.*\" [24h]))",
