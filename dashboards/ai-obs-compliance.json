      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum by (ai_o11y_specialist) (count_over_time({container=\"llm-gateway\"} | json | ai_o11y_specialist=~\"sb-security-handler|sb-hiring-helper\" [5m]))",
          "legendFormat": "{{ai_o11y_specialist}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "📈 Guardrail events over time — by specialist",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Ten users with the most sb-security-handler events in the last 24h. The names at the top are the people most often bumping up against your policies — start any compliance review here.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          },
          "unit": "short"
