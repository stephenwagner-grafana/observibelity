  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 0},
      "id": 1,
      "panels": [],
      "title": "Cascade indicators",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "USD spent on email cascades in the last hour. Each cascade is ~$2.80.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 0, "y": 1},
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum(increase(gen_ai_usage_cost_total_usd{ai_o11y_usecase=\"email-cascade\"}[1h]))",
          "refId": "A"
        }
      ],
      "title": "$ spent on cascades (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "Number of email-cascade runs in the last hour.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 6, "y": 1},
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum(increase(supportbot_email_cascade_run_total[1h]))",
          "refId": "A"
        }
      ],
      "title": "Cascade runs (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "Total tokens consumed by the email-cascade use case (1h). Each run is ~450k.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "thresholds"},
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100000},
              {"color": "red", "value": 500000}
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 5, "w": 6, "x": 12, "y": 1},
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum(increase(gen_ai_usage_input_tokens_total{ai_o11y_usecase=\"email-cascade\"}[1h])) + sum(increase(gen_ai_usage_output_tokens_total{ai_o11y_usecase=\"email-cascade\"}[1h]))",
          "refId": "A"
        }
      ],
      "title": "Cascade tokens (1h)",
      "type": "stat"
    },
    {
      "datasource": {"type": "grafana", "uid": "-- Grafana --"},
