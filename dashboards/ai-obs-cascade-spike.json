{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${datasource_loki}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "name": "Email cascade runs",
        "tagKeys": "conv_id,employee",
        "target": {
          "expr": "{namespace=\"observibelity\",container=\"llm-gateway\"} |~ \"\\\\[email-cascade\\\\] llm/summarize idx=1/2000\"",
          "queryType": "range",
          "refId": "Annotations"
        },
        "textFormat": "cascade started \u2014 {{ conv_id }}"
      }
    ]
  },
  "description": "Email cascade detection: $2.80 per run, ~450k tokens, 2000 tool + 2000 LLM calls. Runaway tool-call spend.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "ai-observability",
        "phase-2"
      ],
      "title": "AI Observability dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "panels": [],
      "title": "Cascade indicators",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "USD spent on email cascades in the last hour. Each cascade is ~$2.80.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(increase(gen_ai_client_cost_USD_total{ai_o11y_specialist=~\"sb-escalator|sb-ticket-helper\"}[1h]))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "USD",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "$ spent on cascades (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Number of email-cascade runs in the last hour.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum(count_over_time({namespace=\"observibelity\",container=\"llm-gateway\"} | json | ai_o11y_specialist=~\"sb-escalator|sb-ticket-helper\" [1h]))",
          "legendFormat": "runs",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Cascade runs (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Total tokens consumed by the email-cascade use case (1h). Each run is ~450k.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 100000
              },
              {
                "color": "red",
                "value": 500000
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(increase(gen_ai_client_token_usage_total{ai_o11y_specialist=~\"sb-escalator|sb-ticket-helper\"}[1h]))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "tokens",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Cascade tokens (1h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "grafana",
        "uid": "-- Grafana --"
      },
      "description": "Alert state \u2014 conv_runaway, the cascade alarm.",
      "gridPos": {
        "h": 5,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "id": 5,
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "conv_runaway",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 10,
        "sortOrder": 3,
        "stateFilter": {
          "error": true,
          "firing": true,
          "noData": false,
          "normal": true,
          "pending": true
        },
        "viewMode": "list"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "grafana",
            "uid": "-- Grafana --"
          },
          "queryType": "alerts",
          "refId": "A"
        }
      ],
      "title": "conv_runaway alert state",
      "type": "alertlist"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 6,
      "panels": [],
      "title": "Per-session cascade pattern",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Emails sent per session over time. A cascade looks like one session emitting many email_sent events in quick succession.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "sum"
          ],
          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "topk(10, sum by (ai_o11y_persona_id) (count_over_time({namespace=\"observibelity\",container=\"llm-gateway\"} | json | ai_o11y_specialist=\"sb-escalator\" [5m])))",
          "legendFormat": "{{ai_o11y_persona_id}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Emails sent per session (5m, top 10)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Distribution of emails-per-session across all sessions. A heavy right tail = runaway cascades.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "hideFrom": {
              "legend": false,
              "tooltip": false,
              "viz": false
            },
            "scaleDistribution": {
              "type": "linear"
            }
          }
        },
        "overrides": []
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 8,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {
          "color": "rgba(255,0,255,0.7)"
        },
        "filterValues": {
          "le": 1e-09
        },
        "legend": {
          "show": true
        },
        "rowsFrame": {
          "layout": "auto"
        },
        "tooltip": {
          "show": true,
          "yHistogram": false
        },
        "yAxis": {
          "axisPlacement": "left",
          "reverse": false
        }
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "sum by (ai_o11y_persona_id) (count_over_time({namespace=\"observibelity\",container=\"llm-gateway\"} | json | ai_o11y_specialist=\"sb-escalator\" [5m]))",
          "legendFormat": "{{ai_o11y_persona_id}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Emails per session \u2014 distribution heatmap",
      "type": "heatmap"
