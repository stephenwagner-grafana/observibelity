  "description": "Email cascade detection: $2.80 per run, ~450k tokens, 2000 tool + 2000 LLM calls. Runaway tool-call spend.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true,
