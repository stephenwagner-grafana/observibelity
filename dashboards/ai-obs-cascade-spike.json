        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Emails in 10m"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "topk(20, sum by (ai_o11y_persona_id) (count_over_time({namespace=\"observibelity\",container=\"llm-gateway\"} | json | ai_o11y_specialist=\"sb-escalator\" [10m])))",
          "legendFormat": "{{ai_o11y_persona_id}}",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Sessions with > 50 emails in last 10m",
      "type": "table"
