      "gridPos": {"h": 5, "w": 6, "x": 18, "y": 1},
      "id": 5,
      "options": {
        "alertInstanceLabelFilter": "",
        "alertName": "conv_runaway",
        "dashboardAlerts": false,
        "groupBy": [],
        "groupMode": "default",
        "maxItems": 10,
        "sortOrder": 3,
        "stateFilter": {"error": true, "firing": true, "noData": false, "normal": true, "pending": true},
        "viewMode": "list"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "grafana", "uid": "-- Grafana --"},
          "queryType": "alerts",
          "refId": "A"
        }
      ],
      "title": "conv_runaway alert state",
      "type": "alertlist"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 6},
      "id": 6,
      "panels": [],
      "title": "Per-session cascade pattern",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "Emails sent per session over time. A cascade looks like one session emitting many email_sent events in quick succession.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "palette-classic"},
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": true
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 0, "y": 7},
      "id": 7,
      "options": {
        "legend": {"displayMode": "table", "placement": "right", "showLegend": true, "calcs": ["sum"]},
        "tooltip": {"mode": "multi", "sort": "desc"}
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "topk(10, sum by (conv_id) (rate(supportbot_email_sent_total[5m])))",
          "legendFormat": "{{conv_id}}",
          "refId": "A"
        }
      ],
      "title": "Emails sent per session (5m, top 10)",
      "type": "timeseries"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "Distribution of emails-per-session across all sessions. A heavy right tail = runaway cascades.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-GrYlRd"},
          "custom": {"hideFrom": {"legend": false, "tooltip": false, "viz": false}, "scaleDistribution": {"type": "linear"}}
        },
        "overrides": []
      },
      "gridPos": {"h": 9, "w": 12, "x": 12, "y": 7},
      "id": 8,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": {
          "exponent": 0.5,
          "fill": "dark-orange",
          "mode": "scheme",
          "reverse": false,
          "scale": "exponential",
          "scheme": "Oranges",
          "steps": 64
        },
        "exemplars": {"color": "rgba(255,0,255,0.7)"},
        "filterValues": {"le": 1e-9},
        "legend": {"show": true},
        "rowsFrame": {"layout": "auto"},
        "tooltip": {"show": true, "yHistogram": false},
        "yAxis": {"axisPlacement": "left", "reverse": false}
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum by (le) (rate(supportbot_emails_per_session_bucket[5m]))",
          "format": "heatmap",
          "legendFormat": "{{le}}",
          "refId": "A"
        }
      ],
      "title": "Emails per session — distribution heatmap",
      "type": "heatmap"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 16},
      "id": 9,
      "panels": [],
      "title": "Top runaway sessions",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
      "description": "Sessions with more than 50 emails in the last 10 minutes — drill-down for incident investigation.",
      "fieldConfig": {
        "defaults": {
          "color": {"mode": "continuous-GrYlRd"},
          "custom": {"align": "auto", "cellOptions": {"type": "auto"}},
          "thresholds": {
            "mode": "absolute",
            "steps": [{"color": "green", "value": null}, {"color": "red", "value": 50}]
          },
          "unit": "short"
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "conv_id"},
            "properties": [{"id": "displayName", "value": "Conversation"}, {"id": "custom.width", "value": 320}]
          },
          {
            "matcher": {"id": "byName", "options": "Value"},
            "properties": [
              {"id": "displayName", "value": "Emails in 10m"},
              {"id": "custom.cellOptions", "value": {"mode": "gradient", "type": "color-background"}}
            ]
          }
        ]
      },
      "gridPos": {"h": 10, "w": 24, "x": 0, "y": 17},
      "id": 10,
      "options": {
        "cellHeight": "sm",
        "footer": {"countRows": false, "fields": "", "reducer": ["sum"], "show": false},
        "showHeader": true,
        "sortBy": [{"desc": true, "displayName": "Emails in 10m"}]
      },
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "topk(20, sum by (conv_id) (increase(supportbot_email_sent_total[10m])) > 50)",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Sessions with > 50 emails in last 10m",
      "type": "table"
    },
    {
