          },
          "expr": "topk(10, sum by (ai_o11y_persona_id) (sum_over_time({namespace=\"observibelity\",container=\"llm-gateway\"} | json | ai_o11y_persona_id!=\"\" | ai_o11y_specialist=~\"sb-.*\" | unwrap gen_ai_usage_input_tokens [1h])))",
          "legendFormat": "{{ai_o11y_persona_id}}",
