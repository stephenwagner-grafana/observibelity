    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 45},
      "id": 19,
      "panels": [],
      "title": "Live event stream",
      "type": "row"
    },
    {
      "datasource": {"type": "loki", "uid": "${datasource_loki}"},
      "description": "Live SupportBot event stream — dangerous events, refusals, escalations.",
      "gridPos": {"h": 11, "w": 24, "x": 0, "y": 46},
      "id": 20,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
