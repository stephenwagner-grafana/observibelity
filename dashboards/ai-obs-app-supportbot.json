      "options": {
        "displayMode": "gradient",
        "minVizHeight": 12,
        "minVizWidth": 8,
        "orientation": "horizontal",
        "reduceOptions": {"calcs": ["lastNotNull"], "fields": "", "values": false},
        "showUnfilled": true,
        "valueMode": "color"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "topk(8, sum by (employee) (increase(supportbot_prompt_injection_events_total{employee!=\"\"}[1h])))",
