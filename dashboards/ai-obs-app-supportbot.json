            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=\"supportbot\"}[5m])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "p99",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "p99 latency (5m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
