{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Total /chat invocations across all categories — drives request-volume signal in RCA.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(support_copilot_chat_duration_seconds_count[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Chat requests (last $__range)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Chat turns that surfaced a tool failure to the shopper. Should track the mice-query rate.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(support_copilot_chat_errors_total{category=~\"$category\"}[$__range]))",
          "refId": "A"
        }
      ],
      "title": "Surfaced failures",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "errors / total tool invocations (last 5m).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(support_copilot_tool_errors_total{tool=~\"$tool\",category=~\"$category\"}[5m])) / sum(rate(support_copilot_tool_duration_seconds_count{tool=~\"$tool\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "Tool error rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(support_copilot_chat_duration_seconds_bucket[5m])))",
          "refId": "A"
        }
      ],
      "title": "p95 e2e chat latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Tool-level p95. Spike to ≥1.5s on mice queries is the RCA signal.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 1.5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(support_copilot_tool_duration_seconds_bucket{tool=\"search_products\"}[5m])))",
          "refId": "A"
        }
      ],
      "title": "p95 search_products latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(support_copilot_tool_errors_total{error_type=\"DatabaseError\",category=~\"$category\"}[5m]))",
          "refId": "A"
        }
      ],
      "title": "DatabaseError errors (5m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 200,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "histogram_quantile(0.95) of support_copilot_tool_duration_seconds, grouped by tool. The mice failure shows as a step up to ≥1.5s on the search_products series.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, tool) (rate(support_copilot_tool_duration_seconds_bucket{tool=~\"$tool\"}[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "p95 latency by tool.name",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 8,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, outcome) (rate(support_copilot_chat_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 — {{outcome}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, outcome) (rate(support_copilot_chat_duration_seconds_bucket[5m])))",
          "legendFormat": "p50 — {{outcome}}",
          "refId": "B"
        }
      ],
      "title": "p95 e2e chat latency",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 300,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Per-tool error fraction over 5-minute windows.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 9,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (tool) (rate(support_copilot_tool_errors_total{tool=~\"$tool\",category=~\"$category\"}[5m])) / sum by (tool) (rate(support_copilot_tool_duration_seconds_count{tool=~\"$tool\"}[5m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Error rate by tool.name",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Errors split by the user-intent category (set on the chat.request span and tool.search_products span). Filter to category=mice to isolate the demo failure.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 10,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (category) (increase(support_copilot_tool_errors_total{category=~\"$category\"}[1m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "title": "Error count by category",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 11,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (tool) (rate(support_copilot_tool_duration_seconds_count{tool=~\"$tool\"}[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A"
        }
      ],
      "title": "Tool requests per second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 12,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (error_type) (increase(support_copilot_tool_errors_total{tool=~\"$tool\",category=~\"$category\"}[1m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A"
        }
      ],
      "title": "Errors by error.type",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 400,
      "title": "Traces — failing requests (Tempo)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "TraceQL: spans named tool.search_products with error.type=DatabaseError. Click the trace ID to drop into the full waterfall (chat.request → agent.turn → tool.search_products → http.search-service → db.postgres.query).",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 13,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"support-copilot\" && name=\"tool.search_products\" && span.error.type=\"DatabaseError\" }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Latest failing traces — DatabaseError",
      "type": "table"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "TraceQL filter on the category attribute. Use the dashboard variable to flip categories.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 14,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"support-copilot\" && span.category=\"$category\" && status=error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces"
        }
      ],
      "title": "Latest failing traces — category=$category",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "id": 500,
      "title": "Logs",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${loki}"
      },
      "description": "Logs include trace_id and span_id — use 'Inspect → Trace' to jump to the corresponding Tempo trace.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 15,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki}"
          },
          "expr": "{namespace=\"observibelity\",container=\"llm-gateway\"} |~ \"(?i)warning|error|trace_id\"",
          "refId": "A"
        }
      ],
      "title": "support-copilot warnings & errors",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "neoncart",
    "ai-observability",
    "rca",
    "demo"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom"
        },
        "name": "prom",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-traces",
          "value": "grafanacloud-traces"
        },
        "name": "tempo",
        "query": "tempo",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-logs",
          "value": "grafanacloud-logs"
        },
        "name": "loki",
        "query": "loki",
        "type": "datasource"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Category",
        "multi": false,
        "name": "category",
        "query": "label_values(support_copilot_tool_errors_total, category)",
        "refresh": 1,
        "type": "query"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Tool",
        "multi": true,
        "name": "tool",
        "query": "label_values(support_copilot_tool_duration_seconds_bucket, tool)",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "NeonCart — AI Observability RCA",
  "uid": "neoncart-ai-o11y"
}
