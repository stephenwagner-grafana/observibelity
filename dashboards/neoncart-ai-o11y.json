        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-traces",
          "value": "grafanacloud-traces"
        },
        "name": "tempo",
        "query": "tempo",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-logs",
          "value": "grafanacloud-logs"
        },
        "name": "loki",
        "query": "loki",
        "type": "datasource"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Use case",
        "multi": false,
        "name": "usecase",
        "query": "label_values(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}, ai_o11y_usecase)",
        "refresh": 1,
        "type": "query",
        "definition": "label_values(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}, ai_o11y_usecase)"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Tool",
        "multi": true,
        "name": "tool",
        "query": "label_values(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}, service)",
        "refresh": 1,
        "type": "query",
        "definition": "label_values(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}, service)"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "NeonCart \u2014 AI Observability RCA (ObserVIBElity)",
  "uid": "neoncart-ai-o11y",
  "description": "NeonCart RCA dashboard. Tool errors, chat latency, mice-rca SQL surface, failing traces. Rewritten to use traces_spanmetrics_* + gen_ai_* (ObserVIBElity convention)."
}