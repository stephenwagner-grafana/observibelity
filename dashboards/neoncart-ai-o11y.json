{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Total /chat invocations across all categories \u2014 drives request-volume signal in RCA.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[$__range]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Chat requests (last $__range)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Chat turns that surfaced a tool failure to the shopper. Should track the mice-query rate.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\",status_code=\"STATUS_CODE_ERROR\"}[$__range]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Surfaced failures",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "errors / total tool invocations (last 5m).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\"}[5m])), 0.001)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Tool error rate",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "p95 e2e chat latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Tool-level p95. Spike to \u22651.5s on mice queries is the RCA signal.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 1.5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=\"search_products\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "p95 search_products latency",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=\"get_inventory\",status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "mice-rca DB errors (5m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 200,
      "title": "Latency",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "histogram_quantile(0.95) of traces_spanmetrics_latency_bucket, grouped by tool. The mice failure shows as a step up to \u22651.5s on the search_products series.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=~\"$tool\"}[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "p95 latency by tool.name",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 8,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status_code) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "legendFormat": "p95 \u2014 {{outcome}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, status_code) (rate(traces_spanmetrics_latency_bucket{service_namespace=\"observibelity\",service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "legendFormat": "p50 \u2014 {{outcome}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "p95 + p50 chat latency by status_code",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 300,
      "title": "Errors",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Per-tool error fraction over 5-minute windows.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 9,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum by (service) (rate(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\"}[5m])), 0.001)",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Error rate by tool.service",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Errors split by the user-intent category (set on the chat.request span and tool.search_products span). Filter to category=mice to isolate the demo failure.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 10,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (ai_o11y_usecase) (rate(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}[1m]))",
          "legendFormat": "{{category}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Token rate by use case",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 11,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\",span_kind=\"SPAN_KIND_SERVER\"}[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Tool requests per second",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 12,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (span_name) (increase(traces_spanmetrics_calls_total{service_namespace=\"observibelity\",service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Errors by span_name",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 400,
      "title": "Traces \u2014 failing requests (Tempo)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "TraceQL: spans named tool.search_products with error.type=DatabaseError. Click the trace ID to drop into the full waterfall (chat.request \u2192 agent.turn \u2192 tool.search_products \u2192 http.search-service \u2192 db.postgres.query).",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 13,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"get_inventory\" && status=error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "expr": "{ resource.service.name=\"get_inventory\" && status=error }",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo}"
          }
        }
      ],
      "title": "Latest failing traces \u2014 get_inventory (mice-rca)",
      "type": "table"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "TraceQL filter on the category attribute. Use the dashboard variable to flip categories.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 14,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"neoncart\" && status=error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "expr": "{ resource.service.name=\"neoncart\" && status=error }",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo}"
          }
        }
      ],
      "title": "Latest failing traces \u2014 NeonCart errors",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "id": 500,
      "title": "Logs",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${loki}"
      },
      "description": "Logs include trace_id and span_id \u2014 use 'Inspect \u2192 Trace' to jump to the corresponding Tempo trace.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 15,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki}"
          },
          "expr": "{namespace=\"observibelity\",container=\"llm-gateway\"} |~ \"(?i)warning|error|trace_id\"",
          "refId": "A"
        }
      ],
      "title": "llm-gateway warnings & errors",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "neoncart",
    "ai-observability",
    "rca",
    "demo"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom"
        },
