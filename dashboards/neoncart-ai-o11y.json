{
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "panels": [
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "title": "📊 At a glance — is NeonCart healthy right now?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Total /chat invocations the storefront has handled over the selected time range. This is the volume baseline \u2014 every other number here should be read against it.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 1
      },
      "id": 1,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[$__range]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "How many chats? (last $__range)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Chat turns where the shopper actually saw an error (a tool failed under the hood). Tracks the mice-query rate during the RCA demo — should climb when 'show me mice' is typed.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 4,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\",status_code=\"STATUS_CODE_ERROR\"}[$__range]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "🚨 How many chats failed?",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Error fraction across all NeonCart tools in the last 5 minutes (errors ÷ total invocations). Yellow at 2%, red at 10%. Filters to the selected tool variable above.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.02
              },
              {
                "color": "red",
                "value": 0.1
              }
            ]
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(rate(traces_spanmetrics_calls_total{service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum(rate(traces_spanmetrics_calls_total{service=~\"$tool\"}[5m])), 0.001)",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "What % of tool calls are failing? (5m)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "95th-percentile end-to-end chat latency over the last 5 minutes — the slowest 1-in-20 shopper experience. Yellow at 2s, red at 4s.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "red",
                "value": 4
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "How slow is chat for the worst 5%? (p95)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "p95 latency of the product-search tool specifically. A spike to \u22651.5s is the smoking gun for the 'show me mice' RCA \u2014 that's the Postgres query timing out before throwing.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 1.5
              }
            ]
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 1
      },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(traces_spanmetrics_latency_bucket{service=\"search_products\"}[5m])))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Is product search slow? (p95, mice-RCA signal)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Errors on the get_inventory tool in the last 5 minutes — the Postgres '42703 column does not exist' error from the mice query. Any non-zero value here = the demo is firing.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 20,
        "y": 1
      },
      "id": 6,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      },
      "targets": [
        {
          "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"get_inventory\",status_code=\"STATUS_CODE_ERROR\"}[5m]))",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "🐭 mice-RCA Postgres errors (5m)",
      "type": "stat"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 200,
      "title": "⏱ Where is the time going?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "p95 latency over time, one line per tool. The mice failure is visible as a step up to \u22651.5s on the search_products series \u2014 every other tool stays flat, which is why the line graph is the give-away.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "id": 7,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, service) (rate(traces_spanmetrics_latency_bucket{service=~\"$tool\"}[5m])))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Which tool is slow? (p95 per tool over time)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "End-to-end chat latency split by outcome (OK vs ERROR). The p50 line is the typical shopper experience; the p95 line is the tail. Failed chats are usually slower than successful ones — the gap tells you how painful errors feel.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "s"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "id": 8,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, status_code) (rate(traces_spanmetrics_latency_bucket{service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "legendFormat": "p95 \u2014 {{outcome}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le, status_code) (rate(traces_spanmetrics_latency_bucket{service=\"neoncart\",span_name=\"POST\",span_kind=\"SPAN_KIND_CLIENT\"}[5m])))",
          "legendFormat": "p50 \u2014 {{outcome}}",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Chat latency — typical vs tail, OK vs failed (p50 & p95)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 300,
      "title": "🚨 What's failing and where?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Error fraction (errors ÷ total) per tool, over time. One line per tool — easy way to see which tool is the bad apple.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineInterpolation": "linear"
          },
          "unit": "percentunit"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 9,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[5m])) / clamp_min(sum by (service) (rate(traces_spanmetrics_calls_total{service=~\"$tool\"}[5m])), 0.001)",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Which tool is failing? (error rate per tool)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Token throughput broken down by use case (mice-RCA, gift finder, refund, etc.). Use this to see which conversation type is driving the load — and during the mice demo, where the spike is concentrated.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 16
      },
      "id": 10,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (ai_o11y_usecase) (rate(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}[1m]))",
          "legendFormat": "{{category}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Which use case is burning tokens? (rate per use case)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "description": "Requests per second handled by each tool (server-side spans). Use this to compare load — search_products usually dominates because it's the gift finder's go-to call.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          },
          "unit": "reqps"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 11,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (service) (rate(traces_spanmetrics_calls_total{service=~\"$tool\",span_kind=\"SPAN_KIND_SERVER\"}[1m]))",
          "legendFormat": "{{tool}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Which tool is busiest? (requests/sec per tool)",
      "type": "timeseries"
    },
    {
      "description": "Stacked bars of errors per minute, broken down by span_name (which specific operation failed). Use to spot exactly which span — db.postgres.query, http.search-service, etc. — is the source of the failure cluster.",
      "datasource": {
        "type": "prometheus",
        "uid": "${prom}"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 12,
      "options": {
        "legend": {
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "expr": "sum by (span_name) (increase(traces_spanmetrics_calls_total{service=~\"$tool\",status_code=\"STATUS_CODE_ERROR\"}[1m]))",
          "legendFormat": "{{error_type}}",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${prom}"
          }
        }
      ],
      "title": "Which span keeps failing? (errors by span name)",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 400,
      "title": "\ud83d\udd0e Pick a failed trace \u2014 drop into the waterfall",
      "type": "row"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "Most recent failing traces on the get_inventory tool \u2014 the mice-RCA smoking gun. Click any trace ID to land in the Tempo waterfall (chat.request \u2192 agent.turn \u2192 tool \u2192 http \u2192 db.postgres.query) and see exactly where it broke.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 13,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"get_inventory\" && status=error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "expr": "{ resource.service.name=\"get_inventory\" && status=error }",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo}"
          }
        }
      ],
      "title": "\ud83d\udc2d Recent mice-RCA failures \u2014 click to open the trace",
      "type": "table"
    },
    {
      "datasource": {
        "type": "tempo",
        "uid": "${tempo}"
      },
      "description": "Most recent NeonCart-wide failing traces (any tool, any use case). Broader than the mice-RCA table above — use this when you don't yet know which tool broke.",
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 14,
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "limit": 20,
          "query": "{ resource.service.name=\"neoncart\" && status=error }",
          "queryType": "traceql",
          "refId": "A",
          "tableType": "traces",
          "expr": "{ resource.service.name=\"neoncart\" && status=error }",
          "datasource": {
            "type": "tempo",
            "uid": "${tempo}"
          }
        }
      ],
      "title": "All recent NeonCart failures \u2014 click to open the trace",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 50
      },
      "id": 500,
      "title": "📜 What did the gateway just log?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${loki}"
      },
      "description": "Warning + error lines from the llm-gateway container. Every line carries trace_id and span_id \u2014 click Inspect \u2192 Trace on any log to jump straight to the matching Tempo trace.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 51
      },
      "id": 15,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "showLabels": false,
        "showTime": true,
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${loki}"
          },
          "expr": "{container=\"llm-gateway\"} |~ \"(?i)warning|error|trace_id\"",
          "refId": "A"
        }
      ],
      "title": "llm-gateway warnings + errors (click → trace)",
      "type": "logs"
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": [
    "neoncart",
    "ai-observability",
    "rca",
    "demo",
    "observibelity"
  ],
  "templating": {
    "list": [
      {
        "current": {
          "text": "grafanacloud-prom",
          "value": "grafanacloud-prom"
        },
        "name": "prom",
        "query": "prometheus",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-traces",
          "value": "grafanacloud-traces"
        },
        "name": "tempo",
        "query": "tempo",
        "type": "datasource"
      },
      {
        "current": {
          "text": "grafanacloud-logs",
          "value": "grafanacloud-logs"
        },
        "name": "loki",
        "query": "loki",
        "type": "datasource"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Use case",
        "multi": false,
        "name": "usecase",
        "query": "label_values(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}, ai_o11y_usecase)",
        "refresh": 1,
        "type": "query",
        "definition": "label_values(gen_ai_client_token_usage_total{ai_o11y_usecase!=\"\"}, ai_o11y_usecase)"
      },
      {
        "current": {
          "text": "All",
          "value": "$__all"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${prom}"
        },
        "includeAll": true,
        "label": "Tool",
        "multi": true,
        "name": "tool",
        "query": "label_values(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}, service)",
        "refresh": 1,
        "type": "query",
        "definition": "label_values(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}, service)"
      }
    ]
  },
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "title": "NeonCart \u2014 AI Observability RCA (ObserVIBElity)",
  "uid": "neoncart-ai-o11y",
  "description": "NeonCart RCA dashboard. Tool errors, chat latency, mice-rca SQL surface, failing traces. Rewritten to use traces_spanmetrics_* + gen_ai_* (ObserVIBElity convention)."
}
