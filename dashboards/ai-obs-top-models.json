      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h]))",
          "format": "table",
          "instant": true,
          "legendFormat": "calls",
          "range": false,
          "refId": "calls"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (label_replace(increase(ai_recommendation_addtocart_total[24h]), \"gen_ai_request_model\", \"$1\", \"model\", \"(.+)\"))",
          "format": "table",
          "instant": true,
          "legendFormat": "atc",
          "range": false,
          "refId": "atc"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "100 * sum by (gen_ai_request_model) (label_replace(increase(ai_recommendation_addtocart_total[24h]), \"gen_ai_request_model\", \"$1\", \"model\", \"(.+)\")) / clamp_min(sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h])), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "atc_rate",
          "range": false,
          "refId": "atc_rate"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\"}[24h])) / clamp_min(sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h])), 1)",
          "format": "table",
          "instant": true,
          "legendFormat": "cost_per_conv",
          "range": false,
          "refId": "cost_per_conv"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "histogram_quantile(0.95, sum by (le, gen_ai_request_model) (rate(gen_ai_client_operation_duration_seconds_bucket{service_namespace=\"observibelity\"}[1h]))) < +Inf",
          "format": "table",
          "instant": true,
          "legendFormat": "p95",
          "range": false,
          "refId": "p95"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "(sum by (gen_ai_request_model) (rate(sigil_eval_scores_total{evaluator=\"quality.business_value_score\"}[1h])) / clamp_min(sum by (gen_ai_request_model) (rate(sigil_eval_executions_total{evaluator=\"quality.business_value_score\"}[1h])), 0.0001) * 100) < +Inf",
          "format": "table",
          "instant": true,
          "legendFormat": "quality",
          "range": false,
          "refId": "quality"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "(\n  40 * (\n    (sum by (gen_ai_request_model) (label_replace(increase(ai_recommendation_addtocart_total[24h]), \"gen_ai_request_model\", \"$1\", \"model\", \"(.+)\")) or sum by (gen_ai_request_model) (0 * increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h])))\n    / clamp_min(sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h])), 1)\n  )\n)\n+\n(\n  30 / clamp_min(\n    1 + (sum by (gen_ai_request_model) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\"}[24h])) / clamp_min(sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h])), 1)) * 1000,\n    1\n  )\n)\n+\n(\n  (15 / clamp_min(1 + (histogram_quantile(0.95, sum by (le, gen_ai_request_model) (rate(gen_ai_client_operation_duration_seconds_bucket{service_namespace=\"observibelity\"}[1h]))) < +Inf), 1))\n  or sum by (gen_ai_request_model) (0 * increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h]))\n)\n+\n(\n  (15 * (sum by (gen_ai_request_model) (rate(sigil_eval_scores_total{evaluator=\"quality.business_value_score\"}[1h])) / clamp_min(sum by (gen_ai_request_model) (rate(sigil_eval_executions_total{evaluator=\"quality.business_value_score\"}[1h])), 0.0001)) < +Inf)\n  or sum by (gen_ai_request_model) (0 * increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\"}[24h]))\n)",
          "format": "table",
          "instant": true,
          "legendFormat": "composite",
          "range": false,
          "refId": "composite"
        }
      ],
