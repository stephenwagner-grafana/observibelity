{
  "uid": "ai-obs-model-matrix",
  "title": "AI o11y \u2014 Model Matrix (which LLM fits which specialist)",
  "tags": [
    "ai-o11y",
    "models"
  ],
  "schemaVersion": 39,
  "timezone": "browser",
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "datasource_prom",
        "label": "Prometheus",
        "type": "datasource",
        "query": "prometheus",
        "current": {
          "selected": true,
          "text": "grafanacloud-stephenwagner-prom",
          "value": "grafanacloud-prom"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      },
      {
        "name": "datasource_loki",
        "label": "Loki",
        "type": "datasource",
        "query": "loki",
        "current": {
          "selected": true,
          "text": "grafanacloud-stephenwagner-logs",
          "value": "grafanacloud-logs"
        },
        "hide": 0,
        "includeAll": false,
        "multi": false,
        "options": [],
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 3
      },
      "options": {
        "mode": "markdown",
        "content": "# \ud83c\udfaf Model Matrix \u2014 which LLM is best for each specialist\n\nPairs every specialist (nc-chatbot, sb-router, nc-gift-finder, ...) against every model in the rotation to surface the **right model per job** by throughput, cost, and quality."
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "\ud83d\udcca Throughput \u2014 output tokens/sec per (specialist \u00d7 model)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 3,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Output tokens/sec \u2014 by specialist \u00d7 model",
      "description": "Output token generation rate. Higher = more throughput on this specialist+model pair.",
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (ai_o11y_specialist, gen_ai_response_model) (rate(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[5m]))",
          "legendFormat": "{{ai_o11y_specialist}} \u00b7 {{gen_ai_response_model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "fillOpacity": 0,
            "stacking": {}
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "lastNotNull"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      }
    },
    {
      "id": 101,
      "type": "row",
      "title": "\ud83d\udcb0 Cost per 1k calls by pair",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 3,
      "type": "table",
      "title": "Cost per 1k calls (USD) \u2014 by specialist \u00d7 model",
      "description": "Lower is better. Computed from last 1h. Excludes pairs with no traffic.",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "1000 * sum by (ai_o11y_specialist, gen_ai_response_model) (increase(gen_ai_client_cost_USD_total[1h])) / clamp_min(sum by (ai_o11y_specialist, gen_ai_response_model) (increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[1h]) / 60), 1)",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_namespace": true,
              "deployment_environment": true
            }
          }
        }
      ]
    },
    {
      "id": 4,
      "type": "table",
      "title": "Avg output tokens per call \u2014 by specialist \u00d7 model",
      "description": "How verbose each model is per specialist. Useful to spot models that ramble or are too terse.",
      "gridPos": {
        "x": 12,
        "y": 15,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (ai_o11y_specialist, gen_ai_response_model) (increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"output\"}[1h])) / clamp_min(sum by (ai_o11y_specialist, gen_ai_response_model) (increase(gen_ai_client_token_usage_total{gen_ai_token_type=\"input\"}[1h]) > 0) * 1, 1)",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_namespace": true,
              "deployment_environment": true
            }
          }
        }
      ]
    },
    {
      "id": 102,
      "type": "row",
      "title": "\u2705 Evaluator pass-rate by (specialist \u00d7 model)",
      "collapsed": false,
      "gridPos": {
        "x": 0,
        "y": 25,
        "w": 24,
        "h": 1
      },
      "panels": []
    },
    {
      "id": 5,
      "type": "table",
      "title": "Eval pass rate \u2014 by specialist \u00d7 model",
      "description": "Fraction of LLM-judge evaluations that passed for each pair. Combine with throughput + cost to pick a model.",
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_agent_name, gen_ai_request_model) (rate(sigil_eval_executions_total{status=\"success\"}[1h])) / clamp_min(sum by (gen_ai_agent_name, gen_ai_request_model) (rate(sigil_eval_executions_total[1h])), 0.001)",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_namespace": true,
              "deployment_environment": true
            }
          }
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Eval runs per specialist + model (last 1h)",
      "description": "Volume of LLM-judge evaluations. Low counts = unreliable pass-rate.",
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (gen_ai_agent_name, gen_ai_request_model, evaluator) (increase(sigil_eval_executions_total[1h]))",
          "instant": true,
          "format": "table"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto"
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "service_name": true,
              "service_namespace": true,
              "deployment_environment": true
            }
          }
        }
      ]
    }
  ]
}