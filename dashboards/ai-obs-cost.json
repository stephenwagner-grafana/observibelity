        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              },
              {
                "color": "green",
                "value": 0.01
              },
              {
                "color": "super-light-green",
                "value": 1
              }
            ]
          },
          "unit": "currencyUSD"
        },
        "overrides": []
