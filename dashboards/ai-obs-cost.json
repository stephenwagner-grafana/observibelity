      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_usage_cost_total_usd[1h]))",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "Cost share by model (1h)",
      "type": "piechart"
    },
    {
      "collapsed": false,
      "gridPos": {"h": 1, "w": 24, "x": 0, "y": 31},
      "id": 12,
      "panels": [],
      "title": "Cost by app / specialist",
      "type": "row"
    },
    {
      "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
