      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "${datasource_prom}"},
          "expr": "sum by (service, ai_o11y_specialist) (rate(gen_ai_usage_cost_total_usd{ai_o11y_specialist!=\"\"}[5m]))",
          "legendFormat": "{{service}} / {{ai_o11y_specialist}}",
