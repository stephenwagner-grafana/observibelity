          "displayMode": "table",
          "placement": "right",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum by (ai_o11y_specialist) (rate(gen_ai_client_cost_USD_total[5m]))",
          "format": "time_series",
          "instant": false,
          "legendFormat": "{{ai_o11y_specialist}}",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "Cost over time by app (5m)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
