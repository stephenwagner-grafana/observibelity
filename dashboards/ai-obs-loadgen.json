        "iconColor": "rgba(0, 211, 255, 1)"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "${datasource_prom}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "#A78BFA",
        "name": "Spillover events",
        "expr": "increase(llm_gateway_spillover_total[1m]) > 0",
