        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{user_id!=\"\", ai_o11y_specialist=~\"sb-.*\"}[24h]))",
          "format": "table",
          "instant": true,
          "legendFormat": "__auto",
          "range": false,
          "refId": "Calls"
