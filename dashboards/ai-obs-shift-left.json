    {
      "id": 6,
      "type": "timeseries",
      "title": "Use case spend velocity (USD/hr)",
      "description": "Which use case is most expensive to run continuously. Use this to pick which ones survive into prod and which stay in the local-only dev tier.",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 10
