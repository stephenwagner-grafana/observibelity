    {
      "id": 7,
      "type": "timeseries",
      "title": "Calls/min — NeonCart vs SupportBot",
      "description": "Specialist calls per minute (5m rate × 60). Each conversation can produce multiple specialist calls (router → downstream), so this is upper-bound on real-user convos.",
      "gridPos": {
        "x": 0,
        "y": 34,
