              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ai_o11y_tool"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Dominant tool"
              },
              {
                "id": "custom.width",
                "value": 220
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Tool calls (10m)"
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "id": 11,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "Tool calls (10m)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "topk(20, sum by (service) (increase(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}[10m])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{service}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "Top sessions with most tool calls (10m)",
      "type": "table"
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 40
      },
      "id": 12,
      "panels": [],
      "title": "Loki \u2014 tool errors",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Tool invocation errors stream.",
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 13,
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showCommonLabels": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "${datasource_loki}"
          },
          "expr": "{container=~\"tool|neoncart|supportbot\"} |~ \"(?i)(error|exception|fail|retry|timeout|traceback)\"",
          "queryType": "range",
          "refId": "A"
        }
      ],
      "title": "Tool errors stream (Loki)",
      "type": "logs"
    }
  ],
