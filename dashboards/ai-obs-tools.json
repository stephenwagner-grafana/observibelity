{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "loki",
          "uid": "${datasource_loki}"
        },
        "enable": true,
        "hide": false,
        "iconColor": "red",
        "name": "Tool runaway alerts",
        "tagKeys": "conv_id,tool_name",
        "target": {
          "expr": "{container=~\".+\"} |~ \"tool_runaway\"",
          "queryType": "range",
          "refId": "Annotations"
        },
        "textFormat": "runaway — {{ conv_id }} / {{ tool_name }}"
      }
    ]
  },
  "description": "Is the agent stuck in a tool-call loop? Top section answers \"is something runaway right now?\"; middle drills into rates and per-session counts; bottom shows tool latency, error rate, and the offending log lines. Source: Tempo span-metrics. Hover the ℹ icon on any panel for what each number means.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {
      "asDropdown": false,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "observibelity"
      ],
      "title": "AI Observability dashboards",
      "type": "dashboards"
    }
  ],
  "liveNow": false,
  "panels": [
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "",
      "type": "timeseries",
      "title": "",
      "id": 100,
      "transparent": true,
      "gridPos": {
        "h": 3,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\",gen_ai_system!=\"\"}[$__rate_interval])) * 60",
          "legendFormat": "tokens/min",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "drawStyle": "bars",
            "barAlignment": 0,
            "barWidthFactor": 0.92,
            "fillOpacity": 100,
            "gradientMode": "scheme",
            "lineWidth": 0,
            "axisPlacement": "hidden",
            "axisLabel": "",
            "axisColorMode": "text",
            "showPoints": "never",
            "spanNulls": false,
            "hideFrom": {
              "legend": true,
              "tooltip": false,
              "viz": false
            },
            "stacking": {
              "group": "A",
              "mode": "none"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "percentage",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 30
              },
              {
                "color": "#F472B6",
                "value": 65
              },
              {
                "color": "#FB923C",
                "value": 88
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "showLegend": false,
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 3
      },
      "id": 1,
      "panels": [],
      "title": "🚨 Runaway detection — is the agent stuck in a loop?",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Across all tools, the highest invocation count any single tool received in the last 10 minutes. ≥20 fires the runaway alert — usually means an agent is hammering the same endpoint in a loop.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "max": 50,
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#86EFAC",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 8,
        "x": 0,
        "y": 4
      },
      "id": 2,
      "options": {
        "minVizHeight": 75,
        "minVizWidth": 75,
        "orientation": "auto",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showThresholdLabels": true,
        "showThresholdMarkers": true
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "max(sum by (service) (increase(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}[10m])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "max",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "🚨 Max calls to a single tool (10m) — runaway gauge",
      "type": "gauge",
      "transparent": false
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Top 10 tools by invocation count over the last 10 minutes. The bar at the top is your prime runaway suspect. Note: query is per-tool (service), not per-conversation — pair with the Top sessions table below to find the offending chat.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 10
              },
              {
                "color": "#F472B6",
                "value": 20
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 8,
        "y": 4
      },
      "id": 3,
      "options": {
        "displayMode": "gradient",
        "minVizHeight": 16,
        "minVizWidth": 8,
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "showUnfilled": true,
        "valueMode": "color"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "topk(10, sum by (service) (increase(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}[10m])))",
          "format": "time_series",
          "instant": true,
          "legendFormat": "{{service}}",
          "range": false,
          "refId": "A"
        }
      ],
      "title": "🔥 Top tools by call count (10m)",
      "type": "bargauge",
      "transparent": false
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource_prom}"
      },
      "description": "Average cost per tool invocation across all tools (1h average). Divides hourly USD spend by hourly tool-call count from Tempo span-metrics. Comparing tools across this metric reveals which ones are token-expensive vs cheap.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 0.001
              },
              {
                "color": "#F472B6",
                "value": 0.01
              }
            ]
          },
          "unit": "currencyUSD",
          "decimals": 4
        },
        "overrides": []
      },
      "gridPos": {
        "h": 5,
        "w": 24,
        "x": 0,
        "y": 11
      },
      "id": 101,
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "textMode": "auto",
        "wideLayout": false,
        "percentChangeColorMode": "inverted"
      },
      "pluginVersion": "11.0.0",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "expr": "sum(rate(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\",gen_ai_system!=\"\"}[5m])) * 3600\n/\nclamp_min(\n  sum(rate(traces_spanmetrics_calls_total{service=~\"create_expense|create_ticket|geo_lookup|get_employee.*|get_inventory|get_order_history|get_product|get_ticket|kb_search|list_tickets|place_order|search_products|request_access|reset_password|update_ticket\"}[5m])) * 3600,\n  1\n)",
          "format": "time_series",
          "instant": false,
          "legendFormat": "USD / tool call",
          "range": true,
          "refId": "A"
        }
      ],
      "title": "💲 $ per tool call (1h average)",
      "type": "stat",
      "transparent": false
    },
