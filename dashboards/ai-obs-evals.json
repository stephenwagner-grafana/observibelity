        "target": {
          "expr": "{namespace=~\"supportbot|neoncart\"} |~ \"evaluator fail\" | logfmt | severity=\"critical\"",
          "queryType": "range",
          "refId": "Annotations"
        },
        "textFormat": "{{ evaluator }} fail"
      }
    ]
  },
  "description": "Evaluator overview — pass/fail rates across all evaluators, with toxicity panels surfaced. Covers the toxicity use case and the all-evaluators status table.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [
    {"asDropdown": false, "icon": "external link", "includeVars": true, "keepTime": true,
