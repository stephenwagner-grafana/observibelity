    {
      "datasource": {
        "type": "loki",
        "uid": "${datasource_loki}"
      },
      "description": "Count of gateway log lines in the last hour matching hallucination signals (hedging phrases, \"fabricated\", \"cannot find\", \"made up\"). Yellow \u22653, red \u226510 \u2014 a sustained climb means the bot is bluffing.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "#8AB8FF",
                "value": null
              },
              {
                "color": "#A78BFA",
                "value": 3
              },
              {
                "color": "#F472B6",
