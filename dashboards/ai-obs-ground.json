        "hide": false,
        "iconColor": "purple",
        "name": "Hallucination events",
        "tagKeys": "category,sku",
        "target": {
          "expr": "{container=\"llm-gateway\"} |~ \"evaluator fail hallucination\"",
          "queryType": "range",
          "refId": "Annotations"
