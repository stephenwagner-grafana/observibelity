          "editorMode": "code",
          "exemplar": false,
          "expr": "( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_usecase=\"high-waste\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) * 100 ) or ( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) * 0 )",
          "format": "time_series",
          "instant": false,
          "range": true,
          "refId": "Waste"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "label_replace( sum by (user_id) (rate(sigil_eval_scores_total{evaluator=\"quality.business_value_score\", gen_ai_agent_name=~\"sb-.*\"}[1h])) / sum by (user_id) (rate(sigil_eval_executions_total{evaluator=\"quality.business_value_score\", gen_ai_agent_name=~\"sb-.*\"}[1h])) * 100, \"user_id\", \"$1\", \"user_id\", \"(.*)\")",
          "format": "time_series",
          "instant": false,
          "range": true,
          "refId": "Quality"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource_prom}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "( (sum by (user_id) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / scalar(max(sum by (user_id) (increase(gen_ai_client_cost_USD_total{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])))) ) * 50 ) + ( ( ( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_usecase=\"high-waste\", ai_o11y_specialist=~\"sb-.*\"}[24h])) / sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) ) or ( sum by (user_id) (increase(gen_ai_client_operation_duration_seconds_count{service_namespace=\"observibelity\", user_id=~\".*@.*\", ai_o11y_specialist=~\"sb-.*\"}[24h])) * 0 ) ) * 0.5 )",
          "format": "time_series",
