{
  "apiVersion": "v1",
  "kind": "Dashboard",
  "metadata": {
    "name": "{{ name }}-per-user-pattern",
    "archetype": "per-user-pattern"
  },
  "templating": {
    "list": [
      {
        "name": "persona_id",
        "type": "query",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values({{ leaderboard_metric }}{usecase=\"{{ name }}\"}, persona_id)",
        "refresh": 2
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Top offenders for {{ name }}",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by (persona_id) ({{ leaderboard_metric }}{usecase=\"{{ name }}\"}))",
          "legendFormat": "{{ '{{persona_id}}' }}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 2,
      "title": "Pattern events over time for {{ name }}",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by (persona_id) (rate({{ leaderboard_metric }}{usecase=\"{{ name }}\"}[5m]))",
          "legendFormat": "{{ '{{persona_id}}' }}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 8
      }
    },
    {
      "id": 3,
      "title": "Drilldown - $persona_id",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "expr": "{usecase=\"{{ name }}\", persona_id=\"$persona_id\"} | json",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 18,
        "h": 8
      }
    },
    {
      "id": 4,
      "title": "Alert state for {{ name }}",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ALERTS{alertname=\"{{ name }}PerUserPattern\", alertstate=\"firing\"}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 18,
        "y": 8,
        "w": 6,
        "h": 8
      }
    }
  ],
  "uid": "ai-obs-cost",
  "title": "Cost \u2014 anomaly per user",
  "tags": [
    "ai-observability",
    "app:both",
    "archetype:per-user-pattern",
    "use_case:cost-anomaly-per-user"
  ]
}
