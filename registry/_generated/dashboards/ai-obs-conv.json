{
  "apiVersion": "v1",
  "kind": "Dashboard",
  "metadata": {
    "name": "{{ name }}-leaderboard",
    "archetype": "leaderboard"
  },
  "panels": [
    {
      "id": 1,
      "title": "Top 10 by {{ rank_by }} grouped by {{ group_by }}",
      "type": "bargauge",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "topk(10, sum by ({{ group_by }}) ({{ rank_by }}{usecase=\"{{ name }}\"}))",
          "legendFormat": "{{ '{{' }} {{ group_by }} {{ '}}' }}",
          "refId": "A"
        }
      ],
      "options": {
        "orientation": "horizontal",
        "displayMode": "gradient"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 10
      }
    },
    {
      "id": 2,
      "title": "{{ rank_by }} trend over 24h",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum by ({{ group_by }}) (rate({{ rank_by }}{usecase=\"{{ name }}\"}[30m]))",
          "legendFormat": "{{ '{{' }} {{ group_by }} {{ '}}' }}",
          "refId": "A"
        }
      ],
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 12,
        "h": 10
      }
    },
    {
      "id": 3,
      "title": "Regression detector (current vs {{ baseline_window }} baseline)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(sum by ({{ group_by }}) (rate({{ rank_by }}{usecase=\"{{ name }}\"}[15m])) / sum by ({{ group_by }}) (avg_over_time({{ rank_by }}{usecase=\"{{ name }}\"}[{{ baseline_window }}]))) - 1",
          "legendFormat": "{{ '{{' }} {{ group_by }} {{ '}}' }}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "orange",
                "value": -0.15
              },
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "gridPos": {
        "x": 0,
        "y": 10,
        "w": 24,
        "h": 6
      }
    }
  ],
  "uid": "ai-obs-conv",
  "title": "Conversations \u2014 refund policy compliance",
  "tags": [
    "ai-observability",
    "app:neoncart",
    "archetype:leaderboard",
    "use_case:refund-policy-compliance"
  ]
}
