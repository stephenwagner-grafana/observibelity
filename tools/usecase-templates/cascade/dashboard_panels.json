{
  "apiVersion": "v1",
  "kind": "Dashboard",
  "metadata": {
    "name": "{{ name }}-cascade",
    "archetype": "cascade"
  },
  "panels": [
    {
      "id": 1,
      "title": "Per-session count for {{ name }}",
      "type": "bargauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "topk(10, sum by (session_id) (increase({{ counter_metric }}{usecase=\"{{ name }}\"}[{{ window }}])))",
          "legendFormat": "{{ '{{session_id}}' }}",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 2,
      "title": "Cascade timeline for {{ name }}",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "sum by (session_id) (rate({{ counter_metric }}{usecase=\"{{ name }}\"}[1m]))",
          "legendFormat": "{{ '{{session_id}}' }}",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8}
    },
    {
      "id": 3,
      "title": "Top offending sessions ({{ window }})",
      "type": "table",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "topk(10, sum by (session_id, persona_id) (increase({{ counter_metric }}{usecase=\"{{ name }}\"}[{{ window }}])))",
          "format": "table",
          "refId": "A"
        }
      ],
      "gridPos": {"x": 0, "y": 8, "w": 16, "h": 8}
    },
    {
      "id": 4,
      "title": "Cumulative damage gauge ({{ name }})",
      "type": "gauge",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "targets": [
        {
          "expr": "max(sum by (session_id) (increase({{ counter_metric }}{usecase=\"{{ name }}\"}[{{ window }}])))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "orange", "value": 1},
              {"color": "red", "value": 5}
            ]
          },
          "min": 0,
          "max": 20
        }
      },
      "gridPos": {"x": 16, "y": 8, "w": 8, "h": 8}
    }
  ]
}
