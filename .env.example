# ObserVIBElity — deployment values.
#
# Copy this file to `.env` and fill in your values:
#     cp .env.example .env && $EDITOR .env
#
# Or run the wizard, which fills it in for you:
#     ./install.sh wizard
#
# `.env` is gitignored. Mode 0600 is enforced by the wizard.

# ═════════════════════════════════════════════════════════════════════════════
# REQUIRED
# ═════════════════════════════════════════════════════════════════════════════

# Phase marker. Phase 0 = scaffolding only. Don't change unless you know why.
PHASE=0

# Which apps to deploy. Phase 0 supports only `neoncart`. Support Bot is Phase 2.
APPS=neoncart

# ─── Anthropic ──────────────────────────────────────────────────────────────
# Anthropic API key. Used by every AI agent and specialist in the demo.
# Get one at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ─── Grafana Cloud ──────────────────────────────────────────────────────────
# Grafana Cloud is the observability backend. Free tier is plenty for this demo.
# Sign up at: https://grafana.com/auth/sign-up/create-user

# Numeric stack instance ID. Find it under "Stack details" in your Grafana Cloud
# account portal (e.g. 1234567).
GRAFANA_CLOUD_INSTANCE_ID=

# Cloud Access Policy token. Grafana Cloud → Security → Access policies →
# create one with scopes: `metrics:write`, `logs:write`, `traces:write`.
GRAFANA_CLOUD_API_TOKEN=

# Region (free-text); used to derive the OTLP endpoint below.
# One of: us-east | us-central | eu-west | ap-southeast
GRAFANA_CLOUD_REGION=us-east

# OTLP gateway endpoint. Defaults to
#   https://otlp-gateway-prod-${GRAFANA_CLOUD_REGION}-0.grafana.net/otlp
# Override only if you have a custom endpoint.
GRAFANA_CLOUD_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-0.grafana.net/otlp

# ─── GitHub ─────────────────────────────────────────────────────────────────
# GitHub Personal Access Token. Used to fork the repo so you can commit your
# customizations. Required unless OBSERVIBELITY_NO_FORK=1.
# Create one with `repo` scope at:
#   https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=

# Org (or username) to fork into. Defaults to your `gh auth status` user.
GITHUB_ORG=

# ─── Ingress ────────────────────────────────────────────────────────────────
# Hostname the ingress controller should serve NeonCart on. The DNS record
# (or /etc/hosts entry) must point at your cluster's ingress IP.
# k3d / docker-desktop users can leave the default and add the entry to
# /etc/hosts: `127.0.0.1 neoncart.localhost`.
INGRESS_HOST_NEONCART=neoncart.localhost

# ═════════════════════════════════════════════════════════════════════════════
# OPTIONAL
# ═════════════════════════════════════════════════════════════════════════════

# ─── Ollama ─────────────────────────────────────────────────────────────────
# Optional external Ollama host. Leave empty to use Claude only for all model
# calls. Example: http://192.168.1.50:11434
# Find / install Ollama at: https://ollama.com/download
OLLAMA_BASE_URL=

# ─── Storage ────────────────────────────────────────────────────────────────
# StorageClass for PVCs. Leave empty to use the cluster's default.
# Run `kubectl get storageclass` to see what's available.
STORAGE_CLASS=
