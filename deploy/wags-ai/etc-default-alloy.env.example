## Path:        /etc/default/alloy
## Description: Grafana Alloy environment file (Debian/Ubuntu package).
## Managed by:  github.com/stephenwagner-grafana/observibelity → deploy/wags-ai/
##
## This is a TEMPLATE. The live file at /etc/default/alloy contains real tokens
## sourced from the k3s secret `observibelity/otel-grafanacloud-creds` and the
## integration tokens in your Grafana Cloud stack settings.
##
## install.sh fetches the live values via `kubectl get secret` automatically.

CONFIG_FILE="/etc/alloy/config.alloy"
CUSTOM_ARGS=""
RESTART_ON_UPGRADE=true

# --- Grafana Cloud Prometheus remote_write ---
GCLOUD_PROM_URL="https://prometheus-prod-XX-prod-us-east-2.grafana.net/api/prom/push"
GCLOUD_PROM_USER="<integration_token_username>"
GCLOUD_PROM_PASS="glc_<integration_token_secret>"

# --- Grafana Cloud Loki ---
GCLOUD_LOKI_URL="https://logs-prod-0XX.grafana.net/loki/api/v1/push"
GCLOUD_LOKI_USER="<integration_token_username>"
GCLOUD_LOKI_PASS="glc_<integration_token_secret>"

# --- Grafana Cloud OTLP gateway ---
# These three come from the k3s secret `observibelity/otel-grafanacloud-creds`:
GCLOUD_OTLP_URL="https://otlp-gateway-prod-us-east-2.grafana.net/otlp"
GCLOUD_OTLP_USER="<GRAFANA_CLOUD_INSTANCE_ID>"
GCLOUD_OTLP_PASS="<GRAFANA_CLOUD_API_TOKEN>"
