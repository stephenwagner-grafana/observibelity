# syntax=docker/dockerfile:1.7
# nc-gift-finder — NeonCart gift-recommendation specialist.
# Thin layer on top of the shared specialist-base image.

ARG SPECIALIST_BASE=ghcr.io/stephenwagner-grafana/observibelity-specialist-base:latest
FROM ${SPECIALIST_BASE}

LABEL org.opencontainers.image.title="observibelity-nc-gift-finder" \
      org.opencontainers.image.description="NeonCart gift recommendation specialist" \
      org.opencontainers.image.source="https://github.com/stephenwagner-grafana/observibelity" \
      org.opencontainers.image.licenses="Apache-2.0"

ENV OTEL_SERVICE_NAME=nc-gift-finder \
    SPECIALIST_NAME=nc-gift-finder

COPY --chown=app:app app/ /app/app/

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
