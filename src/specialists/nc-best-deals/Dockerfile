# syntax=docker/dockerfile:1.7
# nc-best-deals - NeonCart best-deals SKU lookup specialist.
# Thin layer on top of the shared specialist-base image.

ARG SPECIALIST_BASE=ghcr.io/stephenwagner-grafana/observibelity-specialist-base:latest
FROM ${SPECIALIST_BASE}

LABEL org.opencontainers.image.title="observibelity-nc-best-deals" \
      org.opencontainers.image.description="NeonCart best-deals SKU lookup specialist" \
      org.opencontainers.image.source="https://github.com/stephenwagner-grafana/observibelity" \
      org.opencontainers.image.licenses="Apache-2.0"

ENV OTEL_SERVICE_NAME=nc-best-deals \
    SPECIALIST_NAME=nc-best-deals

COPY --chown=app:app app/ /app/app/

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]
